---
import Base from '@/layouts/Base.astro';

const pageTitle = 'Contact';
const pageDescription = 'Contact routes for editorial feedback, business questions, and communication about PowerAI Load Test 01 20260522-042729105.';
---

<Base title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container max-w-3xl">
      <p>Pages</p>
      <h1>{pageTitle}</h1>
      <p>{pageDescription}</p>
      <section class="mb-8">
        <h2>How to reach the publication</h2>
        <p>Use [CONTACT_EMAIL] for general enquiries, editorial notes, and messages that do not need a public reply.</p>
        <p>If a newsletter is added later, it should be kept separate from general contact requests.</p>
      </section>

      <section class="mb-8">
        <h2>What you can send here</h2>
        <p>Use the published email route for general enquiries, corrections, or messages that do not need a formal support queue.</p>
        <p>The contact page is best suited to questions about support requests, account questions, partnership conversations, and product-related enquiries.</p>
      </section>

      <section class="mb-8">
        <h2>What readers should expect</h2>
        <p>Responses, when they are provided, will depend on the type of enquiry and the availability of the editorial team.</p>
        <p>No guaranteed response window is implied unless the site later publishes one as part of a real support or business workflow.</p>
      </section>

      <section class="mb-8">
        <h2>Privacy note</h2>
        <p>Contact messages should be treated as operational communication rather than as public content.</p>
        <p>If more formal handling is required later, the site can add a specific retention or routing policy without changing the basic page structure.</p>
      </section>

      <section class="mb-8">
        <h2>Editorial contact and corrections</h2>
        <p>For publishing sites, this page also acts as the usual place for corrections, tip-offs, partnership enquiries, and requests related to published material.</p>
        <p>If contact routes change later, this page should be updated before the old route is removed from the site.</p>
      </section>
    </div>
  </section>
</Base>
