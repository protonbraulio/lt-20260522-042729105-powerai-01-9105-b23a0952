---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.astro";
import Statistics from "@/components/Statistics";
import CallToAction from "@/partials/CallToAction.astro";
import EssentialFeatures from "@/partials/EssentialFeatures.astro";
import FAQ from "@/partials/FAQ";
import Integration from "@/partials/Integration";
import KeyFeatures from "@/partials/KeyFeatures.astro";
import Pricing from "@/partials/Pricing";
import Testimonials from "@/partials/Testimonials";
import TrustedClients from "@/partials/TrustedClients";
import WhyChooseUs from "@/partials/WhyChooseUs.astro";
import { getListPage } from "@/lib/contentParser";

const homepage = await getListPage("homepage/-index.md");
const trusted_clients = await getListPage("sections/trusted-clients.md");
const key_features = await getListPage("sections/key-features.md");
const essential_features = await getListPage("sections/essential-features.md");
const whyChooseUs = await getListPage("sections/why-choose-us.md");
const integration = await getListPage("sections/integration.md");
const pricing = await getListPage("sections/pricing.md");
const testimonial = await getListPage("sections/testimonial.md");
const faq = await getListPage("sections/faq.md");
const callToAction = await getListPage("sections/call-to-action.md");
const statistics = await getListPage("sections/statistics.md");
const { banner } = homepage.frontmatter;
---

<Base>
  <Hero data={banner} />
  <TrustedClients data={trusted_clients} client:visible />
  <KeyFeatures data={key_features} />
  <Statistics data={statistics} client:visible />
  <EssentialFeatures data={essential_features} />
  <WhyChooseUs data={whyChooseUs} />
  <Integration data={integration} client:visible />
  <Pricing data={pricing} client:visible />
  <Testimonials data={testimonial} client:visible />
  <FAQ data={faq} client:visible />
  <CallToAction data={callToAction} />
</Base>

<section class="content-pack-homepage space-y-10">
  <header class="max-w-3xl space-y-4">
    <p class="text-sm font-semibold uppercase tracking-wide text-slate-600">Featured resource</p>
    <h1 class="text-4xl font-bold leading-tight md:text-5xl text-slate-950">Content Operations Guide</h1>
    <p class="text-lg leading-8 text-slate-700">Explain the core principles of content operations for operations managers building repeatable pipelines in Dublin. Key entities: Content Operations.</p>
  </header>

  <nav class="space-y-3" aria-label="Table of contents">
    <h2 class="text-2xl font-semibold text-slate-950">Table of contents</h2>
    <ul class="list-disc space-y-2 pl-6 text-slate-700">
      <li><a href="#what-content-operations-means-for-operations-managers-building-repeatable-pipelines">What content operations means for operations managers building repeatable pipelines</a></li>
      <li><a href="#what-this-site-covers">What this site covers</a></li>
      <li><a href="#main-framework-and-checklist">Main framework and checklist</a></li>
      <li><a href="#key-subtopics">Key subtopics</a></li>
